<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <link href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
<link href="/css/style.css" rel="stylesheet" />
    <link href="/css/games.css" rel="stylesheet" />
    <title>100 XBOX360 games</title>
  </head>
  <body>
    <%- include('navBar', {currentPage: currentPage}) %>
    <h1 id="title">Games</h1>
    <div class="games glass">
      <search>
        <input id="titleSearch" class="glass" type="text" placeholder="search by title">
      </search>
      <div class="filters">
        <select id="genreFilter" placeholder="Filter by genre...">
        <option value="">All genres</option>
        <% allGenres.forEach(g => { %>
          <option value="<%= g.name %>"><%= g.name %></option>
        <% }) %>
        </select>
        <select id="developerFilter" placeholder="Filter by developer...">
        <option value="">All developers</option>
        <% allDevelopers.forEach(d => { %>
          <option value="<%= d.name %>"><%= d.name %></option>
        <% }) %>
        </select>
      </div>
      <table id="resultsTable">
        <caption class="tableCaption"></caption>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Genres</th>
            <th>Developers</th>
            <th>Year</th>
            <th>About</th>
            <th>Quantity</th>
          </tr>
        <% allData.forEach(row => { %>
          <tr>
            <td><%= row.id %></td>
            <td><%=row.name%></td>
            <td><%=row.genres%></td>
            <td><%=row.developers%></td>
            <td><%=row.release_date%></td>
            <td><a href="<%=row.game_link %>">wiki</a></td>
            <td><%= row.quantity %></td>
          </tr>
          <% }) %>

      </table>
    </div>
    <script>
  new TomSelect('#genreFilter', { maxOptions: null, refreshThrottle: 0, dropdownParent: 'body' });
  new TomSelect('#developerFilter', { maxOptions: null, refreshThrottle: 0, dropdownParent: 'body' });
</script>
  </body>
</html>
