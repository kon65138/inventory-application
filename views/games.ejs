<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <link href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
<link href="/css/style.css" rel="stylesheet" />
    
    <link href="/css/games.css" rel="stylesheet" />
    <title>100 XBOX360 GAMES</title>
  </head>
  <body>
    <script id="gamesData" type="application/json"><%- JSON.stringify(allData).replace(/</g, '\\u003c') %></script>

    <%- include('navBar', {currentPage: currentPage}) %>
    <i class="titleContainer"><h1 id="title"><%= title %></h1></i>
    <div class="games glass">
      <div class="searchAndAdd">
        <search>
        <input id="titleSearch" class="glass" type="text" placeholder="search by title">
      </search>
      <div class="addContainer">
        <button class="add glass"><svg xmlns="http://www.w3.org/2000/svg" height="29.2px" viewBox="0 -960 960 960" width="29.2px" fill="#e3e3e3"><path d="M440-440H200v-80h240v-240h80v240h240v80H520v240h-80v-240Z"/></svg></button>
      </div>
      </div>
      <div class="filters">
        <select id="genreFilter" placeholder="Filter by genre...">
        <option value="">All genres</option>
        <% allGenres.forEach(g => { %>
          <option value="<%= g.name %>"><%= g.name %></option>
        <% }) %>
        </select>
        <select id="developerFilter" placeholder="Filter by developer...">
        <option value="">All developers</option>
        <% allDevelopers.forEach(d => { %>
          <option value="<%= d.name %>"><%= d.name %></option>
        <% }) %>
        </select>
      </div>
      <script>
  new TomSelect('#genreFilter', { maxOptions: null, refreshThrottle: 0, dropdownParent: 'body' });
  new TomSelect('#developerFilter', { maxOptions: null, refreshThrottle: 0, dropdownParent: 'body' });
</script>
      <div class="tableWrapper" >
        <table class="headerTable">
          <tr><th>Name</th><th>Genres</th><th>Developers</th><th>Year</th><th>About</th><th>Quantity</th></tr>
        </table>
        <div class="tableScroll">
          <table id="resultsTable">
              <% allData.forEach(row => { %>
            <tr data-id="<%=row.id%>" class="tableRow">
              <td style="display: none;"><%= row.id %></td>
              <td><%=row.name%></td>
              <td><%=row.genres%></td>
              <td><%=row.developers%></td>
              <td><%=row.release_date%></td>
              <td><a href="<%=row.game_link %>" target="_blank">wiki</a></td>
              <td><%= row.quantity %> <button class="options" onclick="openOptions(event)"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-ellipsis-vertical-icon lucide-ellipsis-vertical"><circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/></svg></button></td>
            </tr>
            <% }) %>
          </table>
        </div>
      </div>
      <script>
  document.querySelector('.tableWrapper').addEventListener('scroll', () => {
  if (popUp.classList.contains('active')) {
    popUp.classList.remove('active');
    popUp.dataset.parentId = 'none';
  }
});

</script>
</script>
    </div>
    <div id="popUp" data-parent-id="none">
      <button class="edit" onclick="openEditForm(event)">Edit<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-pencil-icon lucide-pencil"><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/><path d="m15 5 4 4"/></svg></button>
      <button class="delete" onclick="openDeleteForm(event)">Delete<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trash-icon lucide-trash"><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>
    </div>
    <div class="editWrapper">
      <form method="post" onsubmit="submitHandler(event)" id="editForm" class="glass">
        <h3>Edit Form</h3>
        <label for="editName">
          <div>Name</div>
          <input type="text" value="" id="editName" name="name" class="glass">
        </label>
        <label for="editGenres">
          <div>Genres</div>
          <input type="text" value="" id="editGenres" name="genres" class="glass">
        </label>
        <label for="editDevelopers">
          <div>Developers</div>
          <input type="text" value="" id="editDevelopers" name="developers" class="glass">
        </label>
        <label for="editYear">
          <div>year</div>
          <input type="" value="" id="editYear" name="release_date" class="glass">
        </label>
        <label for="editAbout">
          <div>About</div>
          <input type="text" value="" id="editAbout" name="game_link" class="glass">
        </label>
        <label for="editQuantity">
          <div>Quantity</div>
          <input value="" id="editQuantity" name="quantity" class="glass">
        </label>
        <label for="adminPassword">
          <div>Admin Password</div>
          <input type="password" value="" id="adminPassword" name="adminPassword" class="glass" required>
        </label>
        <ul id="formErrors" class="errorList"></ul>

        <div class="buttons">
          <button class="cancel glass" onclick="cancelBtnHandler()" type="button">Cancel</button>
          <button id="submit" class="glass" type="submit">Edit</button>
        </div>
      </form>
    </div>
    <div class="deleteWrapper">
      <form method="POST" id="deleteForm" class="glass" onsubmit="deleteSubmitHandler(event)">
        <h3>Comfirm Deletion</h3>
        <div class="RUsure"></div>
        <label for="comfimationPassword">
          <div>Admin Password</div>
          <input type="password" value="" id="comfimationPassword" name="adminPassword" class="glass" required>
        </label>
        <ul id="deleteFormErrors" class="errorList"></ul>

        <div class="buttons">
          <button class="cancel glass" onclick="cancelBtnHandler()" type="button">Cancel</button>
          <button id="submit" class="glass" type="submit">Delete</button>
        </div>
      </form>
    </div>
    <div class="addWrapper">
      <form method="post" id="addForm" class="glass" onsubmit="addSubmitHandler(event)">
        <h3>Add Game</h3>
        <label for="addName">
          <div>Name</div>
          <input type="text" name="name" id="addName" class="glass">
        </label>
        <label for="addGenre">
          <div>Genres</div>
          <input type="text" id="addGenre" name="genres" class="glass">
        </label>
        <label for="addDevelopers">
          <div>Developers</div>
          <input type="text" id="addDevelopers" name="developers" class="glass">
        </label>
        <label for="addYear">
          <div>Year</div>
          <input id="addYear" name="release_date" class="glass">
        </label>
        <label for="addAbout">
          <div>About</div>
          <input type="text" id="addAbout" name="game_link" class="glass">
        </label>
        <label for="addQuantity">
          <div>Quantity</div>
          <input id="addQuantity" name="quantity" class="glass">
        </label>
        <label for="addAdminPassword">
          <div>Admin Password</div>
          <input type="password" id="addAdminPassword" name="adminPassword" class="glass" required>
        </label>
        <ul id="addFormErrors" class="errorList"></ul>
        <div class="buttons">
          <button class="cancel glass" type="button" onclick="cancelBtnHandler()">Cancel</button>
          <button id="submit" type="submit" class="glass">Add</button>
        </div>
      </form>
    </div>

<script>
  const editWrapper = document.querySelector('.editWrapper');
  const deleteWrapper = document.querySelector('.deleteWrapper')
  const editform = document.getElementById('editForm');
  const deleteForm = document.getElementById('deleteForm');
  const addForm = document.getElementById('addForm');
  const inputs = document.querySelectorAll('#editForm input');
  const deleteInpt = document.querySelector('#comfimationPassword');
  const addInpts = document.querySelectorAll('#addForm input');
  const list = document.getElementById('formErrors');
  const deleteList = document.getElementById('deleteFormErrors');
  const addList = document.getElementById('addFormErrors');
  const RUsure = document.querySelector('.RUsure');
  const addButton = document.querySelector('.add');
  const addWrapper = document.querySelector('.addWrapper');


  function openEditForm(e) {
    const data = JSON.parse(document.getElementById('gamesData').textContent);
 
    const id = Number(popUp.dataset.parentId);
    const currentData = data.find(item => item.id === id);
    inputs[0].value = currentData.name;
    inputs[1].value = currentData.genres;
    inputs[2].value = currentData.developers;
    inputs[3].value = currentData.release_date;
    inputs[4].value = currentData.game_link;
    inputs[5].value = currentData.quantity;
    
    editWrapper.classList.add('active');

  }
  addButton.addEventListener('click', (e) => {
      addWrapper.classList.add('active');
  })
  function cancelBtnHandler() {
    editWrapper.classList.remove('active');
    deleteWrapper.classList.remove('active');
    addWrapper.classList.remove('active');
    for (let input of inputs) {
      input.value = '';
    }
    for (let input of addInpts) {
      input.value = '';
    }
    deleteInpt.value = '';

    list.innerHTML = '';
    deleteList.innerHTML = '';
    addList.innerHTML = '';

  }
  async function submitHandler(e) {
    e.preventDefault();
    const id = popUp.dataset.parentId;
    try {
      const res = await fetch(`/games/edit/${id}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(new FormData(editform)),
    });
    
    if (res.ok) {
      editWrapper.classList.remove('active');
      location.reload()
    }

    if (res.status === 400) {
      const { errors } = await res.json();
      list.innerHTML = errors.map(e => `<li>${e.msg}</li>`).join('');
    }
    } catch(err) {
      console.error(err)
    }
  }

  function openDeleteForm() {
    const data = JSON.parse(document.getElementById('gamesData').textContent);

    const id = Number(popUp.dataset.parentId);
    const currentData = data.find(item => item.id === id);
    RUsure.textContent = `Are you sure you want to delete ${currentData.name} from the DataBase?`;
    deleteWrapper.classList.add('active');
  };

  async function deleteSubmitHandler(e) {
    e.preventDefault();
    const id = popUp.dataset.parentId;
    try {
      const res = await fetch(`/games/delete/${id}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(new FormData(deleteForm)),
    });
    
    if (res.ok) {
      editWrapper.classList.remove('active');
      location.reload()
    }

    if (res.status === 400) {
      const { errors } = await res.json();
      deleteList.innerHTML = errors.map(e => `<li>${e.msg}</li>`).join('');
    }
    } catch(err) {
      console.error(err)
    }


  }
  async function addSubmitHandler(e) {
    e.preventDefault()
    try {
      const res = await fetch(`/games/add`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(new FormData(addForm)),
    });
    
    if (res.ok) {
      addWrapper.classList.remove('active');
      location.reload()
    }

    if (res.status === 400) {
      const { errors } = await res.json();
      addList.innerHTML = errors.map(e => `<li>${e.msg}</li>`).join('');
    }
    } catch(err) {
      console.error(err)
    }
  

  }
</script>
<script>
  const popUp = document.getElementById('popUp');
  const options = document.querySelectorAll('.options');
  document.addEventListener('click', (e) => {
    if (!popUp.classList.contains('active')) return;
    if (editWrapper.classList.contains('active') || deleteWrapper.classList.contains('active')) return;
    if (!popUp.contains(e.target)) {
      popUp.classList.remove('active')
      popUp.dataset.parentId = "none";
    }
  })

  function openOptions (e) {
    const option = e.currentTarget.closest('.options');
    const tableRowId = e.currentTarget.closest('.tableRow').dataset.id;
    e.stopPropagation();
    if (popUp.dataset.parentId === tableRowId) {
      popUp.classList.remove('active');
      popUp.dataset.parentId = "none";

    } else if(popUp.dataset.parentId === 'none') {
      popUp.dataset.parentId = tableRowId;
      const rect = option.getBoundingClientRect();
      popUp.style.top = `${rect.bottom + window.scrollY-50}px`;
      popUp.style.left = `${rect.left +window.scrollX-85}px`;
      popUp.classList.add('active');
    } else {
      const rect = option.getBoundingClientRect();
      popUp.style.top = `${rect.bottom + window.scrollY-50}px`;
      popUp.style.left = `${rect.left +window.scrollX-85}px`;
      popUp.dataset.parentId = tableRowId;
    }
  }

</script>
<script type="module">
  import Fuse from '/libs/fuse.mjs';

  const data = JSON.parse(document.getElementById('gamesData').textContent);

  const fuse = new Fuse(data, { keys: ['name'], threshold: 0.3 });

  const noResultsDiv = document.createElement('div');
  noResultsDiv.textContent = 'no results';
  noResultsDiv.id = 'noResults';
  const tbody = document.querySelector('#resultsTable tbody');
  tbody.appendChild(noResultsDiv);
  noResultsDiv.style.display = 'none';

  const rows = document.querySelectorAll('#resultsTable tr');
  const rowById = new Map([...rows].map(r => [r.dataset.id, r]));
  const titleSearch = document.getElementById('titleSearch');
  const genreFilter = document.getElementById('genreFilter');
  const developerFilter = document.getElementById('developerFilter');
  

  function filterTable() {
  const query = titleSearch.value.trim();
  const genre = genreFilter.value;
  const developer = developerFilter.value;
  const fuseIds = query ? new Set(fuse.search(query).map(r => String(r.item.id))) : null;

  // PHASE 1 — compute from the data array only. No DOM reads, no layout.
  let firstVisible = null, lastVisible = null;

  for (const item of data) {
    const id = String(item.id);
    const show =
      (!fuseIds || fuseIds.has(id)) &&
      (!genre || (item.genres || '').includes(genre)) &&
      (!developer || (item.developers || '').includes(developer));

    const row = rowById.get(id);
    // PHASE 2 — writes only
    row.style.display = show ? '' : 'none';
    row.classList.remove('first-visible', 'last-visible');
    if (show) {
      if (!firstVisible) firstVisible = row;
      lastVisible = row;
    }
  }

  if (firstVisible) firstVisible.classList.add('first-visible');
  if (lastVisible) lastVisible.classList.add('last-visible');
  noResultsDiv.style.display = firstVisible ? 'none' : 'block';
}

function debounce(fn, ms) {
  let timer;
  return () => {
    clearTimeout(timer);
    timer = setTimeout(fn, ms);
  };
}


document.getElementById('titleSearch').addEventListener('input', debounce(filterTable, 500));




  // Tom Select fires 'change' on the underlying <select>
  document.getElementById('genreFilter').addEventListener('change', filterTable);
  document.getElementById('developerFilter').addEventListener('change', filterTable);
  filterTable()
</script>


  </body>
</html>
