  <body>
    <%- include('navBar', {currentPage: currentPage}) %>
    <i><h1 id="title"><%= title %></h1></i>
    <div class="games glass">
      <search>
        <input id="titleSearch" class="glass" type="text" placeholder="search by title">
      </search>
      <div class="filters">
        <select id="genreFilter" placeholder="Filter by genre...">
        <option value="">All genres</option>
        <% allGenres.forEach(g => { %>
          <option value="<%= g.name %>"><%= g.name %></option>
        <% }) %>
        </select>
        <select id="developerFilter" placeholder="Filter by developer...">
        <option value="">All developers</option>
        <% allDevelopers.forEach(d => { %>
          <option value="<%= d.name %>"><%= d.name %></option>
        <% }) %>
        </select>
      </div>
      <div class="tableWrapper glass" data-overlayscrollbars-initialize>
        <table id="resultsTable">
        <caption class="tableCaption"></caption>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Genres</th>
            <th>Developers</th>
            <th>Year</th>
            <th>About</th>
            <th>Quantity</th>
          </tr>
            <% allData.forEach(row => { %>
          <tr data-id="<%=row.id%>" class="tableRow">
            <td><%= row.id %></td>
            <td><%=row.name%></td>
            <td><%=row.genres%></td>
            <td><%=row.developers%></td>
            <td><%=row.release_date%></td>
            <td><a href="<%=row.game_link %>" target="_blank">wiki</a></td>
            <td><%= row.quantity %> <button class="options" onclick="openOptions(event)"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-ellipsis-vertical-icon lucide-ellipsis-vertical"><circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/></svg></button></td>
          </tr>
          <% }) %>

      </table>
      </div>
      
    </div>
    <div id="popUp" data-parent-id="none">
      <button class="edit" onclick="openEditForm()">Edit<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-pencil-icon lucide-pencil"><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/><path d="m15 5 4 4"/></svg></button>
      <button class="delete" onclick="openDeleteComfimation()">Delete<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trash-icon lucide-trash"><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>
    </div>
    <div class="editWrapper">
      <form action="post" id="editForm" class="glass">
        <h3>Edit Form</h3>
        <label for="editName">
          <div>Name</div>
          <input type="text" value="" id="editName" name="name" class="glass">
        </label>
        <label for="editGenres">
          <div>Genres</div>
          <input type="text" value="" id="editGenres" name="genres" class="glass">
        </label>
        <label for="editDevelopers">
          <div>Developers</div>
          <input type="text" value="" id="editDevelopers" name="developers" class="glass">
        </label>
        <label for="editYear">
          <div>year</div>
          <input type="text" value="" id="editYear" name="release_date" class="glass">
        </label>
        <label for="editAbout">
          <div>About</div>
          <input type="text" value="" id="editAbout" name="wiki_link" class="glass">
        </label>
        <label for="editQuantity">
          <div>Quanitity</div>
          <input type="text" value="" id="editQuantity" name="quantity" class="glass">
        </label>
        <label for="adminPassword">
          <div>Admin Password</div>
          <input type="password" value="" id="adminPassword" name="password" class="glass" required>
        </label>
        <div class="buttons">
          <button class="cancel glass" onclick="cancelBtnClickHandler()">Cancel</button>
          <button id="submit" class="glass">Submit</button>
        </div>
      </form>
    </div>
      <script>
  OverlayScrollbarsGlobal.OverlayScrollbars(
    document.querySelector('.tableWrapper'),
    {},{
      scroll: () => {
      if (popUp.classList.contains('active')) {
        popUp.classList.remove('active');
        popUp.dataset.parentId = 'none';
      }
    }
    }
  );
</script>
<script>
  const editWrapper = document.querySelector('.editWrapper');
  const form = document.getElementById('editForm');
  function openEditForm() {
    const inputs = document.querySelectorAll('#editForm input')
    for (let i = 0; i < 6; i++) {
      
    }
    editWrapper.classList.add('active');

  }
  function cancelBtnClickHandler() {
    editWrapper.classList.remove('active');
  }
</script>
<script>
  const popUp = document.getElementById('popUp');
  const options = document.querySelectorAll('.options');
  document.addEventListener('click', (e) => {
    if (!popUp.classList.contains('active')) return;
    if (!popUp.contains(e.target)) {
      popUp.classList.remove('active')
      popUp.dataset.parentId = "none";
    }
  })

  function openOptions (e) {
    const option = e.currentTarget.closest('.options');
    const tableRowId = e.currentTarget.closest('.tableRow').dataset.id;
    e.stopPropagation();
    if (popUp.dataset.parentId === tableRowId) {
      popUp.classList.remove('active');
      popUp.dataset.parentId = "none";

    } else if(popUp.dataset.parentId === 'none') {
      popUp.dataset.parentId = tableRowId;
      const rect = option.getBoundingClientRect();
      popUp.style.top = `${rect.bottom + window.scrollY-50}px`;
      popUp.style.left = `${rect.left +window.scrollX-85}px`;
      popUp.classList.add('active');
    } else {
      const rect = option.getBoundingClientRect();
      popUp.style.top = `${rect.bottom + window.scrollY-50}px`;
      popUp.style.left = `${rect.left +window.scrollX-85}px`;
      popUp.dataset.parentId = tableRowId;
    }
  }
</script>

    <script>
  new TomSelect('#genreFilter', { maxOptions: null, refreshThrottle: 0, dropdownParent: 'body' });
  new TomSelect('#developerFilter', { maxOptions: null, refreshThrottle: 0, dropdownParent: 'body' });
</script>
<script type="module">
  import Fuse from '/libs/fuse.mjs';

  const data = <%- JSON.stringify(allData) %>;
  const fuse = new Fuse(data, { keys: ['name'], threshold: 0.3 });

  const noResultsDiv = document.createElement('div');
      noResultsDiv.textContent = 'no results'
      noResultsDiv.id = 'noResults';
    const tbody = document.querySelector('tbody');
    tbody.appendChild(noResultsDiv);
    noResultsDiv.style.display = 'none';
  

  function filterTable() {
    const query = document.getElementById('titleSearch').value.trim();
    const genre = document.getElementById('genreFilter').value;
    const developer = document.getElementById('developerFilter').value;
    const rows = document.querySelectorAll('#resultsTable tr:not(:first-child)');

    const fuseIds = query
      ? new Set(fuse.search(query).map(r => String(r.item.id)))
      : null;

    rows.forEach(row => {
      const id = row.dataset.id;
      const genres = row.cells[2].textContent;
      const developers = row.cells[3].textContent;

      const matchesTitle = !fuseIds || fuseIds.has(id);
      const matchesGenre = !genre || genres.includes(genre);
      const matchesDev = !developer || developers.includes(developer);

      row.style.display = matchesTitle && matchesGenre && matchesDev ? '' : 'none';
    });



    // update last-visible class for border-radius
    rows.forEach(row => {
      row.classList.remove('first-visible')
      row.classList.remove('last-visible')
    });
    const visibleRows = [...rows].filter(row => row.style.display !== 'none');
    if (visibleRows.length){
      visibleRows.at(0).classList.add('first-visible');
      visibleRows.at(-1).classList.add('last-visible');
    } 
    if (visibleRows == false) {
      noResultsDiv.style.display = 'block';
    } else if (noResultsDiv.style.display === 'block') {   
      noResultsDiv.style.display = 'none';
    }
    

  }

  document.getElementById('titleSearch').addEventListener('input', filterTable);

  // Tom Select fires 'change' on the underlying <select>
  document.getElementById('genreFilter').addEventListener('change', filterTable);
  document.getElementById('developerFilter').addEventListener('change', filterTable);
  filterTable()
</script>


  </body>
</html>
