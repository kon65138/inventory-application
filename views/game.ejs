<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="/css/style.css" rel="stylesheet" />
    <link href="/css/game.css" rel="stylesheet" />
    <title>100 XBOX360 games</title>
  </head>
  <body>
    <div class="navBar">
      <a href="/" id="title">100 XBOX360 GAMES</a>
      <a href="/category" id="categories">categories</a>
    </div>
    <div class="mainContainer">
      <div class="left">
        <div class="gameImgAndTitle">
          <div class="gameImgContainer">
            <img
              src="<%= game.img_src ? game.img_src : '/imgs/javier-martinez-hUD0PUczwJQ-unsplash.jpg' %>"
              alt="videogame thumbnail img"
              class="gameImg"
            />
          </div>
          <h2 class="gameTitle"><%= game.name %></h2>
        </div>
      </div>
      <div class="right">
        <div class="gameInfo">
          <ul class="infoList">
            <li class="">Developers: <%= game.developers %></li>
            <li class="">Genres: <%= game.genres %></li>
            <li class="">Release Date: <%= game.release_date %></li>
            <li class="">
              Wikipedia page:
              <a href="<%= game.game_link %>" target="_blank">link</a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </body>
</html>
