<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="/css/style.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/dashboard.css" />
    <title>100 XBOX360 games</title>
  </head>
  <body>
    <%- include('navBar', {currentPage: currentPage}) %>
    <i class="titleContainer"><h1 id="title"><%= title %></h1></i>
    
    <div class="dashboard glass">
      <div class="statsContainer">
        <div class="totalStock glass" >
        <div class="statName">Total Stock</div>
        <div class="statDisplay">
          <div class="icon"></div>
          <div class="number"data-count="<%= totalStock.sum %>">0</div>
        </div>
      </div>
      <div class="uniqueGames glass" >
        <div class="statName">Unique Games</div>
        <div class="statDisplay">
          <div class="icon"></div>
          <div class="number"data-count="<%= games.length %>">0</div>
        </div>
      </div>
      <div class="lowStock glass">
        <div class="statName">Low Stock</div>
        <div class="statDisplay">
          <div class="icon"></div>
          <div class="number"data-count="<%= lowStock.length %>">0</div>
        </div>
      </div>
      <div class="outOfStock glass" >
        <div class="statName">Out Of Stock</div>
        <div class="statDisplay">
          <div class="icon"></div>
          <div class="number"data-count="<%= outOfStock.length %>">0</div>
        </div>
      </div>
      </div>
      <div class="tables" title="Low Stock Games">
        <div class="chartWrapper glass">
          <canvas id="genreChart"></canvas>
        </div>
        <div class="tableWrapper">
          <div class="headerTableWrapper">
            <table class="headerTable">
              <caption class="tableCaption">low stock games</caption>
              <tr>
                <th>Name</th>
                <th>Quantity</th>
              </tr>
            </table>
          </div>
          <div class="tableScroll">
            <table id="lowStockTable" >
            <% lowStock.forEach(row => {%>
            <tr>
              <td><%= row.name %></td>
              <td><%= row.quantity %></td>
            </tr>
            <% }) %>
          </table>
          </div>
        </div>
      </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const ctx = document.getElementById('genreChart');
  new Chart(ctx, {
    type: 'doughnut', // or 'pie'
    data: {
      labels: <%- JSON.stringify(genresDistribution.map(g => g.name)) %>,
      datasets: [{
        data: <%- JSON.stringify(genresDistribution.map(g => g.game_count)) %>,
        borderWidth: 0,
        hoverOffset: 8,
      }]
    },
    options: {
      maintainAspectRatio: false,
      plugins: {
        title: {display: true, text: 'Genre distribution of unique games'},
        legend: { display: false}
      }
    }
  });
</script>
    <script >
  function countUp(el, target, duration = 1200) {
    const start = performance.now();
    const update = (now) => {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
      el.textContent = Math.floor(eased * target);
      if (progress < 1) requestAnimationFrame(update);
    };
    requestAnimationFrame(update);
  }

  document.querySelectorAll('[data-count]').forEach(el => {
    countUp(el, parseInt(el.dataset.count));
  });

    // Keep the header table the same rendered width as the body table so their
  // fixed-layout columns line up across browsers (Chrome/Firefox size native
  // scrollbars differently, so a hardcoded gutter can't match both).
  const headerTable = document.querySelector('.headerTable');
  const bodyTable = document.getElementById('lowStockTable');

  function syncHeaderWidth() {
    headerTable.style.width = bodyTable.offsetWidth + 'px';
  }

  // Fires on window resize and when the scrollbar appears/disappears as
  // filtering changes the row count.
  new ResizeObserver(syncHeaderWidth).observe(bodyTable);
  syncHeaderWidth();
</script>
  </body>
</html>
